GTOa (4)

ChannelOrder : IPNodeDefinition (1)
{
    node
    {
        string evaluationType = "color"
        string defaultName = "channelOrder"
        string creator = "Sony Pictures Imageworks"
        string documentation = "Custom Channel Order with OCIO compatibility"
        int userVisible = 1
    }

    render
    {  
        int intermediate = 0
    }

    function
    {
        string name = "main"
        string type = "color"
        string glsl = "file://${HERE}/channel_order.glsl"
    }

    parameters
    {
        float[4] channelOrder = [ [ 0.0 1.0 2.0 3.0 ] ]
    }

    documentation
    {
        string summary = "Exact replica of DisplayIPNode channelOrder functionality"
        string html = "Replicates color.channelOrder behavior with R,G,B,A,0,1 support. Works with OCIO."
    }
}